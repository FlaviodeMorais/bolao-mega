# Copie para ".env" nesta mesma pasta e preencha antes de rodar docker compose up -d

# URL pública pela qual o Evolution API vai ser acessado (a mesma que você vai
# colocar em Configurações → WhatsApp → "URL do Evolution API" no admin do Bolão Mega)
SERVER_URL=https://evolution.seudominio.com

# Senha do Postgres interno (gerada por você, não precisa ser memorável)
POSTGRES_PASSWORD=troque-por-uma-senha-forte-aleatoria

# API Key GLOBAL da sua instalação — protege TODOS os endpoints administrativos
# (criar/deletar instâncias). Gere uma string aleatória longa, ex: openssl rand -hex 32
AUTHENTICATION_API_KEY=troque-por-uma-chave-aleatoria-longa
